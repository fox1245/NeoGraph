# Copy this to `.env` (same directory) and fill in your key.
# `_common.py` auto-loads .env from this directory or any parent.

# Required for any example that talks to a real LLM (06, 08, 11-13).
OPENAI_API_KEY=sk-...

# Optional — point at any OpenAI-compatible endpoint.
# Defaults to https://api.openai.com.
# Examples:
#   OPENAI_API_BASE=https://api.groq.com
#   OPENAI_API_BASE=http://localhost:8080   # local llama.cpp / vLLM / Ollama
# OPENAI_API_BASE=https://api.openai.com

# Optional — override the default model name.
# Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini
