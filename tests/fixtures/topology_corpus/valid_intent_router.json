{
  "schema_version": 1,
  "name": "valid_intent_router",
  "channels": {
    "messages": {
      "reducer": "append"
    },
    "__route__": {
      "reducer": "overwrite"
    }
  },
  "nodes": {
    "ic": {
      "type": "intent_classifier",
      "prompt": "math, code, or general",
      "routes": [
        "math",
        "code",
        "general"
      ]
    },
    "m": {
      "type": "llm_call"
    },
    "c": {
      "type": "llm_call"
    },
    "g": {
      "type": "llm_call"
    }
  },
  "edges": [
    {
      "from": "__start__",
      "to": "ic"
    },
    {
      "from": "m",
      "to": "__end__"
    },
    {
      "from": "c",
      "to": "__end__"
    },
    {
      "from": "g",
      "to": "__end__"
    }
  ],
  "conditional_edges": [
    {
      "from": "ic",
      "condition": "route_channel",
      "routes": {
        "math": "m",
        "code": "c",
        "general": "g",
        "default": "g"
      }
    }
  ]
}